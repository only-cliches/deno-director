{
  "name": "deno-director",
  "version": "0.9.30",
  "description": "High-performance Node.js <-> Deno bridge with native worker isolation, fast binary channels, and rich type-safe cross-runtime messaging.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "cargo-cp-artifact -nc index.node -- cargo build --message-format=json-render-diagnostics",
    "install": "npm run build",
    "build-debug": "npm run build -- && tsc --project tsconfig.idx.json",
    "build-release": "npm run build -- --release && tsc --project tsconfig.idx.json",
    "size:ts-js": "node scripts/ts-compiled-js-size.mjs",
    "test-txt": "jest --verbose --silent=false &> test_results.txt",
    "test-json": "jest --json > test_results.json",
    "test": "npm run test:guard:any && cargo test && jest",
    "test:contention": "jest test-ts/contention.spec.ts --runInBand --silent=false --forceExit",
    "test:contention:absurd": "DENO_DIRECTOR_ABSURD_RUNTIMES=40 DENO_DIRECTOR_ABSURD_WAVES=5 DENO_DIRECTOR_ABSURD_STREAMS=16 DENO_DIRECTOR_ABSURD_HOST_CALLS=140 jest test-ts/contention.spec.ts --runInBand --silent=false --forceExit",
    "test:guard:any": "bash codex/check-test-any.sh"
  },
  "keywords": [
    "deno",
    "node",
    "bridge",
    "runtime-bridge",
    "worker",
    "sandbox",
    "isolate",
    "ipc",
    "message-passing",
    "binary-transfer",
    "typedarray",
    "buffer",
    "serialization",
    "cross-runtime",
    "host-functions",
    "module-loader",
    "eval",
    "native-addon",
    "neon",
    "v8",
    "secure-runtime"
  ],
  "author": "me@scottlott.com",
  "license": "MIT",
  "dependencies": {
    "cargo-cp-artifact": "^0.1.9"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^25.0.3",
    "fast-check": "^4.5.2",
    "jest": "^29.7.0",
    "p-limit": "^3.1.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/only-cliches/deno-director.git"
  },
  "bugs": {
    "url": "https://github.com/only-cliches/deno-director/issues"
  },
  "homepage": "https://github.com/only-cliches/deno-director#readme"
}
