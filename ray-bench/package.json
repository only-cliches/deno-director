{
  "name": "ray-bench",
  "version": "1.0.0",
  "description": "IPC and parallelism benchmark for Node and Deno worker paths",
  "main": "src/bench.ts",
  "scripts": {
    "bench": "npx tsx src/bench.ts",
    "bench:256": "npx tsx src/bench.ts --width 256 --height 256 --tile 12 --workers 1,4,8,12 --warmup 2 --iterations 3 --format plain",
    "bench:1024": "npx tsx src/bench.ts --width 1024 --height 1024 --tile 12 --workers 1,4,8,12 --warmup 2 --iterations 3 --format plain",
    "bench:2048": "npx tsx src/bench.ts --width 2048 --height 2048 --tile 12 --workers 1,4,8,12 --warmup 2 --iterations 3 --format plain",
    "bench:4096": "npx tsx src/bench.ts --width 4096 --height 4096 --tile 12 --workers 1,4,8,12 --warmup 2 --iterations 3 --format plain"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
